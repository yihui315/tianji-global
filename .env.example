# TianJi Global Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase (Database) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/tianji_global
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── NextAuth v5 ───────────────────────────────────────────────────────────────
# Used for JWT signing/verification. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth — create at https://console.cloud.google.com/
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Resend — Email Magic Link. Get key at https://resend.com/
# This replaces the old SMTP config (EMAIL_SMTP_* vars are no longer used)
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=TianJi Global <noreply@tianji.global>

# ─── AI Model Providers ───────────────────────────────────────────────────────
# At least ONE of these is required:
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROK_API_KEY=your-xai-api-key
GEMINI_API_KEY=your-google-ai-api-key

# Optional: Custom API endpoints (for proxies/self-hosted)
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GROK_BASE_URL=https://api.x.ai/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Local Ollama (for privacy/offline mode)
OLLAMA_BASE_URL=http://localhost:11434

# Default AI Model Settings
DEFAULT_MODEL_PROVIDER=anthropic
DEFAULT_MODEL=claude-3-5-sonnet-latest

# ─── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=***
STRIPE_WEBHOOK_SECRET=***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── PostgreSQL (Direct DB access — used by Stripe webhook) ────────────────────
DATABASE_URL=postgresql://user:password@host:5432/database

# Stripe Price IDs (create these in your Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# ─── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron Job ─────────────────────────────────────────────────────────────────
CRON_SECRET=your-random-secret-for-cron-auth

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_SECRET=your_webhook_secret_here
